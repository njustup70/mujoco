#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Twist
from sensor_msgs.msg import JointState
import mujoco
import mujoco.viewer
import os
from ament_index_python.packages import get_package_share_directory
import threading
import time

class MujocoRosBridge(Node):
    def __init__(self):
        super().__init__('mujoco_ros2_bridge')
        
        # 加载模型
        package_share_dir = get_package_share_directory('mujoco_ros2_bridge')
        model_path = os.path.join(package_share_dir, 'model', 'robot.xml')
        
        if not os.path.exists(model_path):
            # 兼容开发模式下的路径
            model_path = 'src/mujoco_ros2_bridge/model/robot.xml'

        self.get_logger().info(f'Loading MuJoCo model from: {model_path}')
        
        self.model = mujoco.MjModel.from_xml_path(model_path)
        self.data = mujoco.MjData(self.model)
        
        # 订阅控制指令
        self.cmd_vel_sub = self.create_subscription(
            Twist,
            'cmd_vel',
            self.cmd_vel_callback,
            10)
        
        # 目标速度
        self.target_v_x = 0.0
        self.target_v_y = 0.0
        self.target_v_yaw = 0.0

        # 启动 MuJoCo 仿真线程
        self.stop_event = threading.Event()
        self.thread = threading.Thread(target=self.simulation_loop)
        self.thread.start()

    def cmd_vel_callback(self, msg):
        self.target_v_x = msg.linear.x
        self.target_v_y = msg.linear.y
        self.target_v_yaw = msg.angular.z

    def simulation_loop(self):
        # 使用 passive viewer，这样可以看到仿真画面
        with mujoco.viewer.launch_passive(self.model, self.data) as viewer:
            while not self.stop_event.is_set() and viewer.is_running():
                step_start = time.time()

                # 将 ROS 指令映射到 MuJoCo Actuators
                # 假设 actuator 顺序为 vel_x, vel_y, vel_yaw
                self.data.ctrl[0] = self.target_v_x
                self.data.ctrl[1] = self.target_v_y
                self.data.ctrl[2] = self.target_v_yaw

                # 物理步进
                mujoco.mj_step(self.model, self.data)

                # 同步查看器
                viewer.sync()

                # 控制频率
                time_until_next_step = self.model.opt.timestep - (time.time() - step_start)
                if time_until_next_step > 0:
                    time.sleep(time_until_next_step)

    def destroy_node(self):
        self.stop_event.set()
        self.thread.join()
        super().destroy_node()

def main(args=None):
    rclpy.init(args=args)
    node = MujocoRosBridge()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()
