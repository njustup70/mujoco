<mujoco model="Four_Wheel_Swerve_Chassis">
    <compiler angle="degree" coordinate="local" meshdir="./"/>

    <option gravity="0 0 -9.81" timestep="0.001" iterations="100" tolerance="1e-12">
        <flag contact="enable" energy="enable"/>
    </option>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
        <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="2 2" texuniform="true"/>
    </asset>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" specular=".2 .2 .2" pos="0 0 10" dir="0 0 -1"/>
        <geom name="floor" pos="0 0 0" size="0 0 .25" type="plane" material="matplane" condim="3" friction="2.5 0.01 0.005" solref="0.02 1" solimp="0.9 0.95 0.001"/>

        <body name="chassis" pos="0 0 0.209" euler="0 0 0">
            <freejoint name="root"/>
            
            <geom name="chassis_visual_main" type="box" size="0.4 0.4 0.08" pos="0 0 -0.0" rgba="0.8 0.3 0.3 1" contype="0" conaffinity="0" mass="0"/>
            <!-- <geom name="chassis_visual_top" type="box" size="0.38 0.38 0.01" pos="0 0 0.06" rgba="0.6 0.2 0.2 1" contype="0" conaffinity="0" mass="0"/> -->
            
            <!-- <geom name="chassis_visual_center" type="box" size="0.4 0.4 0.04" pos="-0.02 0 0" rgba="0.8 0.3 0.3 1" contype="0" conaffinity="0" mass="0"/> -->
            <!-- <geom name="chassis_visual_rear" type="box" size="0.16 0.14 0.03" pos="-0.18 0 0.04" rgba="0.8 0.3 0.3 1" contype="0" conaffinity="0" mass="0"/> -->
            <geom name="chassis_mass" type="box" size="0.35 0.25 0.04" pos="0.18 0.057 0.0" rgba="0.8 0.3 0.3 0" mass="16" contype="0" conaffinity="0"/>
            <body name="wheel0_pivot" pos="0.325 0.325 -0.093">
                <joint name="wheel0_steer" type="hinge" axis="0 0 1" damping="2.0" armature="0.01"/>
                <geom type="cylinder" size="0.04 0.02" rgba="0.3 0.3 0.8 1" mass="0.5" contype="0" conaffinity="0"/>
                <body name="wheel0" pos="0 0 -0.058">
                    <joint name="wheel0_drive" type="hinge" axis="0 1 0" damping="2.0" armature="0.05"/>
                    <geom type="cylinder" size="0.058 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" friction="2.5 0.01 0.005" mass="1.0" contype="1" conaffinity="1"/>
                </body>
            </body>

            <body name="wheel1_pivot" pos="0.325 -0.325 -0.093">
                <joint name="wheel1_steer" type="hinge" axis="0 0 1" damping="2.0" armature="0.01"/>
                <geom type="cylinder" size="0.04 0.02" rgba="0.3 0.3 0.8 1" mass="0.5" contype="0" conaffinity="0"/>
                <body name="wheel1" pos="0 0 -0.058">
                    <joint name="wheel1_drive" type="hinge" axis="0 1 0" damping="2.0" armature="0.05"/>
                    <geom type="cylinder" size="0.058 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" friction="2.5 0.01 0.005" mass="1.0" contype="1" conaffinity="1"/>
                </body>
            </body>

            <body name="wheel2_pivot" pos="-0.325 0.325 -0.093">
                <joint name="wheel2_steer" type="hinge" axis="0 0 1" damping="2.0" armature="0.01"/>
                <geom type="cylinder" size="0.04 0.02" rgba="0.3 0.3 0.8 1" mass="0.5" contype="0" conaffinity="0"/>
                <body name="wheel2" pos="0 0 -0.058">
                    <joint name="wheel2_drive" type="hinge" axis="0 1 0" damping="2.0" armature="0.05"/>
                    <geom type="cylinder" size="0.058 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" friction="2.5 0.01 0.005" mass="1.0" contype="1" conaffinity="1"/>
                </body>
            </body>

            <body name="wheel3_pivot" pos="-0.325 -0.325 -0.093">
                <joint name="wheel3_steer" type="hinge" axis="0 0 1" damping="2.0" armature="0.01"/>
                <geom type="cylinder" size="0.04 0.02" rgba="0.3 0.3 0.8 1" mass="0.5" contype="0" conaffinity="0"/>
                <body name="wheel3" pos="0 0 -0.058">
                    <joint name="wheel3_drive" type="hinge" axis="0 1 0" damping="2.0" armature="0.05"/>
                    <geom type="cylinder" size="0.058 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" friction="2.5 0.01 0.005" mass="1.0" contype="1" conaffinity="1"/>
                </body>
            </body>

            <geom name="head_marker" type="box" size="0.05 0.2 0.01" pos="0.18 0 0.07" rgba="0 1 0 1" contype="0" conaffinity="0" mass="0"/>
        </body>
    </worldbody>
    <actuator>
        <position joint="wheel0_steer" name="steer0" kp="50" forcerange="-300 300"/>
        <motor joint="wheel0_drive" name="drive0" gear="1" forcerange="-180 180"/>
        <position joint="wheel1_steer" name="steer1" kp="50" forcerange="-300 300"/>
        <motor joint="wheel1_drive" name="drive1" gear="1" forcerange="-180 180"/>
        <position joint="wheel2_steer" name="steer2" kp="50" forcerange="-300 300"/>
        <motor joint="wheel2_drive" name="drive2" gear="1" forcerange="-180 180"/>
        <position joint="wheel3_steer" name="steer3" kp="50" forcerange="-300 300"/>
        <motor joint="wheel3_drive" name="drive3" gear="1" forcerange="-180 180"/>
    </actuator>
</mujoco>
