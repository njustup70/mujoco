<mujoco model="Omni_Directional_Chassis_STL_Fixed">
    <compiler angle="degree" coordinate="local" meshdir="./"/>

    <option gravity="0 0 -9.81"/>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
        <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="2 2" texuniform="true"/>
    </asset>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" specular=".2 .2 .2" pos="0 0 10" dir="0 0 -1"/>
        
        <geom name="floor" type="plane" size="10 10 0.1" material="matplane" friction ="1 0.005 0.005"/>

        <body name="chassis" pos="0.0 0.0 0.1" euler="0 0 270">
            <joint name="root_x" type="slide" axis="1 0 0" damping="10"/>
            <joint name="root_y" type="slide" axis="0 1 0" damping="10"/>
            <joint name="root_z" type="hinge" axis="0 0 1" damping="5"/>
            
            <!-- Main Chassis Body -->
            <geom type="box" size="0.3 0.2 0.05" rgba="0.8 0.3 0.3 1" mass="10"/>

            <!-- Front Head Marker (Green) -->
            <geom name="head_marker" type="box" size="0.05 0.2 0.01" pos="0.25 0 0.055" rgba="0 1 0 1" contype="0" conaffinity="0" mass="0"/>
            
            <!-- Headlights (White Cylinders) -->
            <geom name="headlight_left" type="cylinder" size="0.03 0.01" pos="0.3 0.12 0" zaxis="1 0 0" rgba="1 1 1 1" contype="0" conaffinity="0" mass="0"/>
            <geom name="headlight_right" type="cylinder" size="0.03 0.01" pos="0.3 -0.12 0" zaxis="1 0 0" rgba="1 1 1 1" contype="0" conaffinity="0" mass="0"/>

            <!-- Wheels (Decorative for now) -->
            <geom type="cylinder" size="0.08 0.04" pos="0.25  0.23 0" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0"/>
            <geom type="cylinder" size="0.08 0.04" pos="-0.25  0.23 0" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0"/>
            <geom type="cylinder" size="0.08 0.04" pos="0.25 -0.23 0" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0"/>
            <geom type="cylinder" size="0.08 0.04" pos="-0.25 -0.23 0" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" contype="0" conaffinity="0"/>
        </body>
    </worldbody>

    <actuator>
        <velocity joint="root_x" name="vel_x" kv="500"/> 
        <velocity joint="root_y" name="vel_y" kv="500"/> 
        <velocity joint="root_z" name="vel_yaw" kv="100"/> 
    </actuator>
</mujoco>
