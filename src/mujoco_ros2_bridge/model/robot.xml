<mujoco model="Four_Wheel_Swerve_Chassis">
    <compiler angle="degree" coordinate="local" meshdir="./"/>

    <option gravity="0 0 -9.81" timestep="0.001" iterations="100" tolerance="1e-12">
        <flag contact="enable" energy="enable"/>
    </option>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
        <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="2 2" texuniform="true"/>
    </asset>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" specular=".2 .2 .2" pos="0 0 10" dir="0 0 -1"/>
        <geom name="floor" pos="0 0 0" size="0 0 .25" type="plane" material="matplane" condim="3" friction="1.0 0.01 0.005" solref="0.02 1" solimp="0.9 0.95 0.001"/>

        <body name="chassis" pos="0 0 0.21" euler="0 0 0">
            <freejoint name="root"/>
            <geom type="box" size="0.35 0.25 0.04" rgba="0.8 0.3 0.3 1" mass="50"/>

            <!-- Wheel 0: Front Left -->
            <body name="wheel0_pivot" pos="0.25 0.2 -0.05">
                <joint name="wheel0_steer" type="hinge" axis="0 0 1" damping="2.0" armature="0.01"/>
                <geom type="cylinder" size="0.04 0.02" rgba="0.3 0.3 0.8 1" mass="1" contype="0" conaffinity="0"/>
                <body name="wheel0" pos="0 0 -0.08">
                    <joint name="wheel0_drive" type="hinge" axis="0 1 0" damping="2.0" armature="0.05"/>
                    <geom type="cylinder" size="0.08 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" friction="1.2 0.01 0.005" mass="2" contype="1" conaffinity="1"/>
                </body>
            </body>

            <!-- Wheel 1: Front Right -->
            <body name="wheel1_pivot" pos="0.25 -0.2 -0.05">
                <joint name="wheel1_steer" type="hinge" axis="0 0 1" damping="2.0" armature="0.01"/>
                <geom type="cylinder" size="0.04 0.02" rgba="0.3 0.3 0.8 1" mass="1" contype="0" conaffinity="0"/>
                <body name="wheel1" pos="0 0 -0.08">
                    <joint name="wheel1_drive" type="hinge" axis="0 1 0" damping="2.0" armature="0.05"/>
                    <geom type="cylinder" size="0.08 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" friction="1.2 0.01 0.005" mass="2" contype="1" conaffinity="1"/>
                </body>
            </body>

            <!-- Wheel 2: Rear Left -->
            <body name="wheel2_pivot" pos="-0.25 0.2 -0.05">
                <joint name="wheel2_steer" type="hinge" axis="0 0 1" damping="2.0" armature="0.01"/>
                <geom type="cylinder" size="0.04 0.02" rgba="0.3 0.3 0.8 1" mass="1" contype="0" conaffinity="0"/>
                <body name="wheel2" pos="0 0 -0.08">
                    <joint name="wheel2_drive" type="hinge" axis="0 1 0" damping="2.0" armature="0.05"/>
                    <geom type="cylinder" size="0.08 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" friction="1.2 0.01 0.005" mass="2" contype="1" conaffinity="1"/>
                </body>
            </body>

            <!-- Wheel 3: Rear Right -->
            <body name="wheel3_pivot" pos="-0.25 -0.2 -0.05">
                <joint name="wheel3_steer" type="hinge" axis="0 0 1" damping="2.0" armature="0.01"/>
                <geom type="cylinder" size="0.04 0.02" rgba="0.3 0.3 0.8 1" mass="1" contype="0" conaffinity="0"/>
                <body name="wheel3" pos="0 0 -0.08">
                    <joint name="wheel3_drive" type="hinge" axis="0 1 0" damping="2.0" armature="0.05"/>
                    <geom type="cylinder" size="0.08 0.02" zaxis="0 1 0" rgba="0.2 0.2 0.2 1" friction="1.2 0.01 0.005" mass="2" contype="1" conaffinity="1"/>
                </body>
            </body>

            <geom name="head_marker" type="box" size="0.05 0.2 0.01" pos="0.25 0 0.055" rgba="0 1 0 1" contype="0" conaffinity="0" mass="0"/>
        </body>
    </worldbody>

    <actuator>
        <position joint="wheel0_steer" name="steer0" kp="20" forcerange="-60 60"/>
        <velocity joint="wheel0_drive" name="drive0" kv="20" forcerange="-60 60"/>
        <position joint="wheel1_steer" name="steer1" kp="20" forcerange="-60 60"/>
        <velocity joint="wheel1_drive" name="drive1" kv="20" forcerange="-60 60"/>
        <position joint="wheel2_steer" name="steer2" kp="20" forcerange="-60 60"/>
        <velocity joint="wheel2_drive" name="drive2" kv="20" forcerange="-60 60"/>
        <position joint="wheel3_steer" name="steer3" kp="20" forcerange="-60 60"/>
        <velocity joint="wheel3_drive" name="drive3" kv="20" forcerange="-60 60"/>
    </actuator>
</mujoco>
