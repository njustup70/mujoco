<mujoco model="Block_Virtual_Force_Chassis">
    <compiler angle="degree" coordinate="local" meshdir="./"/>

    <option gravity="0 0 -9.81" timestep="0.001" iterations="100" tolerance="1e-12">
        <flag contact="enable" energy="enable"/>
    </option>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
        <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 0.15 0.2" width="512" height="512" mark="cross" markrgb=".8 .8 .8"/>
        <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="2 2" texuniform="true"/>
    </asset>

    <worldbody>
        <light directional="true" diffuse=".8 .8 .8" specular=".2 .2 .2" pos="0 0 10" dir="0 0 -1"/>
        <geom name="floor" pos="0 0 0" size="0 0 .25" type="plane" material="matplane" condim="3" friction="0.05 0.005 0.0005" solref="0.02 1" solimp="0.9 0.95 0.001"/>

        <body name="chassis" pos="0 0 0.209" euler="0 0 0">
            <freejoint name="root"/>

            <!-- 可视化主体 -->
            <geom name="chassis_visual_main" type="box" size="0.4 0.4 0.08" pos="0 0 0.0" rgba="0.8 0.3 0.3 1" contype="0" conaffinity="0" mass="0"/>

            <!-- 单一接触块：用于替代原舵轮接触 -->
            <geom
                name="contact_block"
                type="box"
                size="0.325 0.325 0.058"
                pos="0 0 -0.151"
                rgba="0.2 0.2 0.2 0.35"
                friction="0.00 0.000 0.0000"
                contype="1"
                conaffinity="1"
                mass="0"/>

            <!-- 等效质量分布（总质量约 22kg）：
                 16kg 偏置主块 + 四角各 1.5kg -->
            <geom name="mass_main" type="box" size="0.35 0.25 0.04" pos="0.18 0.057 0.0" rgba="0.8 0.3 0.3 0" mass="16" contype="0" conaffinity="0"/>
            <geom name="mass_corner0" type="sphere" size="0.02" pos="0.325 0.325 -0.151" rgba="0 0 0 0" mass="1.5" contype="0" conaffinity="0"/>
            <geom name="mass_corner1" type="sphere" size="0.02" pos="0.325 -0.325 -0.151" rgba="0 0 0 0" mass="1.5" contype="0" conaffinity="0"/>
            <geom name="mass_corner2" type="sphere" size="0.02" pos="-0.325 0.325 -0.151" rgba="0 0 0 0" mass="1.5" contype="0" conaffinity="0"/>
            <geom name="mass_corner3" type="sphere" size="0.02" pos="-0.325 -0.325 -0.151" rgba="0 0 0 0" mass="1.5" contype="0" conaffinity="0"/>

            <geom name="head_marker" type="box" size="0.05 0.2 0.01" pos="0.18 0 0.07" rgba="0 1 0 1" contype="0" conaffinity="0" mass="0"/>
        </body>
    </worldbody>
</mujoco>
